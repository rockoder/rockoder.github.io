---
import BaseLayout from '../layouts/BaseLayout.astro';

const messages = [
  "Looks like this page took an unexpected detour.",
  "This page is playing hide and seek. It's winning.",
  "The page you're looking for is on a coffee break.",
  "404: Page not found. But you found this, so that's something.",
  "This URL leads nowhere. Much like my debugging sessions at 3 AM.",
];

const randomMessage = messages[Math.floor(Math.random() * messages.length)];
---

<BaseLayout title="Page Not Found">
  <div class="mx-auto max-w-3xl px-4 py-24 sm:px-6 lg:px-8 text-center">
    <div class="mb-8">
      <span class="text-8xl font-bold bg-gradient-to-r from-[var(--accent)] to-[var(--foreground-muted)] bg-clip-text text-transparent">
        404
      </span>
    </div>

    <h1 class="text-2xl font-semibold text-[var(--foreground)] mb-4">
      Page Not Found
    </h1>

    <p class="text-lg text-[var(--foreground-muted)] mb-8 max-w-md mx-auto">
      {randomMessage}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--accent)] text-white rounded-lg hover:bg-[var(--accent-hover)] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        Go Home
      </a>

      <a
        href="/blog/"
        class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--border)] text-[var(--foreground)] rounded-lg hover:border-[var(--border-hover)] hover:bg-[var(--background-secondary)] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        Read Blog
      </a>
    </div>

    <p class="text-sm text-[var(--foreground-subtle)] mt-12">
      If you think this is a mistake, feel free to
      <a href="mailto:ganesh@rockoder.com" class="text-[var(--accent)] hover:underline">let me know</a>.
    </p>
  </div>
</BaseLayout>
